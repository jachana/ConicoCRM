# Conico frontend — example environment file.
# Copy to `.env.local` for local dev or set in your deploy platform.

# Backend API base URL (e.g. http://localhost:8000 or https://api.conico.cl)
VITE_API_URL=

# Sentry — leave empty to disable error reporting.
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
