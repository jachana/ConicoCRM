DATABASE_URL=postgresql://conico:CHANGE_ME@db:5432/conico
SECRET_KEY=run-openssl-rand-hex-32-to-generate
POSTGRES_DB=conico
POSTGRES_USER=conico
POSTGRES_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# W1-02 — Backups Postgres
# ---------------------------------------------------------------------------
# Schedule del cron interno del contenedor `backups`. Cron-style o @daily/@hourly.
BACKUP_SCHEDULE=@daily
# Retención (rotación a cargo de prodrigestivill/postgres-backup-local).
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# ---------------------------------------------------------------------------
# Offsite copy (opcional). Dejar S3_BUCKET vacío para desactivar.
# Soporta S3 nativo, Backblaze B2, Wasabi, MinIO, etc. (rclone).
# ---------------------------------------------------------------------------
S3_BUCKET=
S3_PREFIX=conico-prod
S3_ENDPOINT=
S3_REGION=us-east-1
S3_PROVIDER=Other
S3_KEY=
S3_SECRET=

# ---------------------------------------------------------------------------
# W1-06 — Observabilidad (Sentry + structured logs)
# ---------------------------------------------------------------------------
# Deja SENTRY_DSN vacío para desactivar Sentry (init es no-op si DSN está vacío).
SENTRY_DSN=
SENTRY_ENV=production
# Sample rate de tracing (0.0 = sin traces, 1.0 = 100%). Recomendado prod: 0.05-0.1.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Release tag opcional (si no se setea, init_sentry intenta derivar de git rev).
SENTRY_RELEASE=

# json = una línea JSON por log (recomendado prod, ingesta a Loki/CloudWatch).
# pretty = colorizado human-readable (solo dev).
LOG_FORMAT=json
LOG_LEVEL=INFO
